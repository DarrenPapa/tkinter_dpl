import "tkinter_main.py" "@loc"
import "to_callable.py"
import "text_io.py"

pycatch [app] _mods.py.tkinter.tk_window "My tkinter app using DPL!" "350x200"

# This turns any dpl code into runnable python functions!
body _mods.py.to_callable button_function []
    _mods.py.io println Yey
    _mods.py.io flush
end

pycatch [my_label] _mods.py.tkinter.tk_label %app "This is a test label!"
_mods.py.tkinter.tk_pack %my_label

# Make a button that can be clicked!
pycatch [my_button] _mods.py.tkinter.tk_button %app "Click me!" %button_function
_mods.py.tkinter.tk_pack %my_button

_mods.py.tkinter.tk_mainloop %app